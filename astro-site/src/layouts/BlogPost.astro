---
// Layout for blog posts written in Markdown (src/pages/blog/*.md).
// Each Markdown file sets `layout: ../../layouts/BlogPost.astro` plus the
// frontmatter fields read below. The post body renders into <slot />.
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
const {
  title,
  description,
  category = "Notes",
  date,
  readTime,
  badge = "POST",
  heroLabel = "cover image",
  heroCaption,
  tags = [],
  prev,
  next,
} = frontmatter;
---

<BaseLayout title={`${title} — Ngwashi Anthony`} active="blog">
  <main data-screen-label="Blog post">
    <div class="post-wrap crumb"><a href="/blog">← Blog</a></div>

    <header class="post-wrap post-hd">
      <span class="tag tag-accent post-cat">{category}</span>
      <h1>{title}</h1>
      {description && <p class="standfirst">{description}</p>}
      <div class="byline">
        <span class="av">NA</span>
        <div>
          <div class="bl-name">Ngwashi Anthony</div>
          <div class="bl-meta">
            <span>{date}</span><span class="dot"></span><span>{readTime}</span><span class="dot"></span><span>{badge}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="post-wrap">
      <figure class="lead-fig">
        <div class="frame">
          <span class="frame-corner tl"></span><span class="frame-corner tr"></span>
          <span class="frame-corner bl"></span><span class="frame-corner br"></span>
          <span class="frame-label">{heroLabel}</span>
        </div>
        {heroCaption && <figcaption>{heroCaption}</figcaption>}
      </figure>

      <article class="article">
        <slot />
      </article>

      <footer class="post-foot">
        <div class="ft-tags">
          <span class="ft-label">Filed under</span>
          {tags.map((t, i) => (
            <span class={i === 0 ? "tag tag-accent" : "tag"}>{t}</span>
          ))}
        </div>

        <div class="prevnext">
          {prev ? (
            <a class="pn prev" href={prev.url}>
              <div class="dir"><span class="arrow">←</span> Previous</div>
              <div class="t">{prev.title}</div>
            </a>
          ) : <span></span>}
          {next ? (
            <a class="pn next" href={next.url}>
              <div class="dir">Next <span class="arrow">→</span></div>
              <div class="t">{next.title}</div>
            </a>
          ) : <span></span>}
        </div>
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  .post-wrap { max-width: 720px; margin: 0 auto; padding-inline: var(--gutter); }

  .crumb { padding-block: 28px 0; }
  .crumb a { font-family: var(--mono); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-3); }
  .crumb a:hover { color: var(--accent); }

  .post-hd { padding-block: 30px 30px; }
  .post-hd .post-cat { margin-bottom: 18px; }
  .post-hd h1 { font-size: clamp(34px, 5.2vw, 54px); letter-spacing: -0.032em; font-weight: 500; line-height: 1.02; }
  .post-hd .standfirst { font-size: clamp(18px, 2.1vw, 21px); color: var(--ink-2); margin: 22px 0 0; line-height: 1.5; }
  .byline { display: flex; align-items: center; gap: 14px; margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--line); }
  .byline .av { width: 38px; height: 38px; border-radius: 50%; background: var(--ink); color: var(--paper); display: grid; place-items: center; font-family: var(--mono); font-size: 13px; font-weight: 600; }
  .byline .bl-meta { font-family: var(--mono); font-size: 12px; color: var(--ink-3); letter-spacing: 0.04em; display: flex; align-items: center; gap: 9px; }
  .byline .bl-name { font-size: 15px; font-weight: 500; color: var(--ink); }

  .lead-fig { margin: 8px 0 44px; }
  .lead-fig .frame { aspect-ratio: 16 / 8; }
  figcaption { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; color: var(--ink-3); margin-top: 9px; }

  /* article body — markdown output is slotted, so target it with :global() */
  .article { font-size: 18px; line-height: 1.72; color: #2a2823; }
  .article :global(p) { margin: 0 0 1.35em; }
  .article :global(h2) { font-size: 27px; letter-spacing: -0.02em; margin: 48px 0 14px; font-weight: 600; line-height: 1.1; color: var(--ink); }
  .article :global(h2)::before { content: ""; display: block; width: 26px; height: 2px; background: var(--accent); margin-bottom: 16px; }
  .article :global(h3) { font-size: 20px; margin: 32px 0 10px; font-weight: 600; color: var(--ink); }
  .article :global(a) { color: inherit; border-bottom: 1px solid var(--accent-line); }
  .article :global(a:hover) { border-color: var(--accent); }
  .article :global(strong) { font-weight: 600; color: var(--ink); }
  .article :global(ul) { margin: 0 0 1.35em; padding-left: 0; list-style: none; }
  .article :global(li) { position: relative; padding-left: 26px; margin-bottom: 10px; }
  .article :global(li)::before { content: "—"; position: absolute; left: 0; color: var(--accent); font-family: var(--mono); }
  .article :global(blockquote) { margin: 32px 0; padding: 6px 0 6px 22px; border-left: 2px solid var(--accent); font-size: 21px; line-height: 1.5; color: var(--ink); letter-spacing: -0.01em; }
  .article :global(blockquote p) { margin: 0; }

  /* inline code */
  .article :global(code) { font-family: var(--mono); font-size: 0.85em; background: var(--paper-2); border: 1px solid var(--line); padding: 1px 5px; border-radius: 3px; }
  /* fenced code blocks (Shiki) */
  .article :global(pre) { margin: 28px 0; padding: 18px; border-radius: 5px; border: 1px solid var(--line-2); overflow-x: auto; font-size: 13.5px; line-height: 1.7; }
  .article :global(pre code) { background: none; border: 0; padding: 0; font-size: inherit; }

  /* raw-HTML helpers usable inside markdown */
  .article :global(.pull-note) { font-family: var(--mono); font-size: 13px; line-height: 1.6; color: var(--ink-2); background: var(--paper-2); border: 1px solid var(--line); border-radius: 5px; padding: 16px 18px; margin: 28px 0; }
  .article :global(.pull-note b) { color: var(--accent); }
  .article :global(.diagram) { margin: 32px 0; }
  .article :global(.diagram .frame) { aspect-ratio: 16 / 7; }
  .article :global(figure) { margin: 28px 0; }

  .post-foot { border-top: 1px solid var(--line); margin-top: 56px; padding-top: 28px; }
  .post-foot .ft-tags { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .post-foot .ft-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); }

  .prevnext { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 36px; }
  .pn { border: 1px solid var(--line); border-radius: 5px; padding: 20px; transition: border-color .15s, background .15s; }
  .pn:hover { border-color: var(--line-2); background: var(--paper-2); }
  .pn .dir { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .pn .t { font-size: 17px; font-weight: 500; margin-top: 8px; letter-spacing: -0.015em; }
  .pn.next { text-align: right; }
  .pn .arrow { color: var(--accent); }

  @media (max-width: 520px) { .prevnext { grid-template-columns: 1fr; } }
</style>
