---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects.js";

// Featured projects come from the shared data file (src/data/projects.js).
const featured = projects.find((p) => p.featured) ?? projects[0] ?? null;
const sideProjects = projects.filter((p) => p !== featured).slice(0, 2);
const hasProjects = projects.length > 0;

// Latest writing is pulled straight from the Markdown posts, newest first,
// so this section never goes stale — add a post and it appears here.
const modules = import.meta.glob("./blog/*.md", { eager: true });
const latestPosts = Object.values(modules)
  .map((m) => ({ ...m.frontmatter, url: m.url }))
  .sort((a, b) => b.order - a.order)
  .slice(0, 3);
---

<BaseLayout title="Ngwashi Anthony — Mechatronics Student" active="home">
  <main data-screen-label="Home">
    <!-- ============ HERO ============ -->
    <section class="hero wrap">
      <div class="hero-grid">
        <div>
          <span class="kicker">Portfolio &amp; Build Notes — Student</span>
          <h1 class="display">
            <span class="name-line">Ngwashi Anthony.</span>
            <span class="role-line">Mechatronics Student.</span>
          </h1>
          <p class="lede hero-tag">Learning to make things move — one Arduino sketch, one soldered joint at a time.</p>
          <div class="hero-cta">
            <a class="btn" href="/projects">View projects <span class="arrow">→</span></a>
            <a class="btn btn-ghost" href="/blog">Read the blog</a>
          </div>
        </div>
        <aside class="hero-aside">
          <div class="mono mono-accent" style="margin-bottom:16px;">// currently</div>
          <div class="stat-row"><span class="k">Year</span><span class="v">2nd-year B.Eng</span></div>
          <div class="stat-row"><span class="k">Learning</span><span class="v">Arduino · KiCad</span></div>
          <div class="stat-row"><span class="k">Bench</span><span class="v">Breadboard + iron</span></div>
          <div class="stat-row"><span class="k">Club</span><span class="v">Robotics society</span></div>
          <div class="stat-row"><span class="k">Status</span><span class="v accent">Open to internships</span></div>
        </aside>
      </div>
    </section>

    <hr class="divider wrap" style="border:0;height:1px;background:var(--line);" />

    <!-- ============ FEATURED PROJECTS ============ -->
    <section class="home-projects wrap">
      <div class="sec-head">
        <div>
          <span class="kicker">01 / Things I've built</span>
          <h2 class="h-lg" style="margin-top:14px;">Featured projects</h2>
        </div>
        <a class="txtlink" href="/projects">All projects <span class="arrow">→</span></a>
      </div>

      {hasProjects ? (
        <div class="feat-grid">
          <a class="card feat-main" href={`/projects/${featured.slug}`}>
            <div class="frame">
              <span class="frame-corner tl"></span><span class="frame-corner tr"></span>
              <span class="frame-corner bl"></span><span class="frame-corner br"></span>
              <span class="frame-label">{featured.label}</span>
            </div>
            <div class="feat-body">
              <div class="mono">PROJ-{featured.num} · {featured.year}</div>
              <h3 class="h-md">{featured.title}</h3>
              <p class="muted" style="margin:0;">{featured.blurb}</p>
              <div class="tags" style="margin-top:6px;">
                {featured.tags.map((t, i) => <span class={i === 0 ? "tag tag-accent" : "tag"}>{t}</span>)}
              </div>
            </div>
          </a>

          {sideProjects.length > 0 && (
            <div class="feat-side">
              {sideProjects.map((p) => (
                <a class="card" href={`/projects/${p.slug}`}>
                  <div class="frame"><span class="frame-label">{p.label}</span></div>
                  <div class="feat-body">
                    <div class="mono">PROJ-{p.num} · {p.year}</div>
                    <h3 class="h-md" style="font-size:21px;">{p.title}</h3>
                    <div class="tags">
                      {p.tags.map((t, i) => <span class={i === 0 ? "tag tag-accent" : "tag"}>{t}</span>)}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      ) : (
        <div class="feat-empty">
          <span class="mono mono-accent">// nothing here yet</span>
          <p>My first projects are coming soon. Until then, the build logs on the <a href="/blog">blog</a> show what I'm working on.</p>
        </div>
      )}
    </section>

    <!-- ============ LATEST POSTS ============ -->
    <section class="home-blog wrap">
      <div class="sec-head">
        <div>
          <span class="kicker">02 / From the bench</span>
          <h2 class="h-lg" style="margin-top:14px;">Latest writing</h2>
        </div>
        <a class="txtlink" href="/blog">All posts <span class="arrow">→</span></a>
      </div>

      <div class="post-list">
        {latestPosts.map((p) => (
          <a class="post-row" href={p.url}>
            <span class="pr-date">{p.date}</span>
            <span>
              <span class="pr-title">{p.title}</span>
              <span class="pr-excerpt" style="display:block;">{p.description}</span>
            </span>
            <span class={`pr-cat tag ${p.category === "Tutorial" ? "tag-accent" : ""}`}>{p.category}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero { padding-block: clamp(56px, 9vw, 104px) clamp(48px, 7vw, 80px); }
  .hero-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: clamp(28px, 5vw, 64px); align-items: end; }
  .hero-grid > * { min-width: 0; }
  .hero h1 { margin: 22px 0 0; overflow-wrap: break-word; hyphens: auto; }
  .hero .name-line { display: block; }
  .hero .role-line { display: block; color: var(--ink-3); font-weight: 400; }
  .hero-tag { margin-top: 26px; max-width: 30ch; }
  .hero-cta { margin-top: 32px; display: flex; gap: 14px; flex-wrap: wrap; }

  .hero-aside { border: 1px solid var(--line); border-radius: 5px; background: var(--paper); padding: 22px; }
  .stat-row { display: flex; justify-content: space-between; align-items: baseline; padding: 13px 0; border-bottom: 1px dashed var(--line-2); }
  .stat-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .stat-row:first-child { padding-top: 0; }
  .stat-row .k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-3); }
  .stat-row .v { font-size: 16px; font-weight: 500; }

  .home-projects { padding-block: clamp(48px, 7vw, 80px) 0; }
  .feat-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 24px; }
  .feat-main .frame { aspect-ratio: 16 / 10; }
  .feat-side { display: flex; flex-direction: column; gap: 24px; }
  .feat-side .card { flex-direction: row; }
  .feat-side .card .frame { width: 132px; flex: none; aspect-ratio: auto; border-bottom: 0; border-right: 1px solid var(--line); }
  .feat-body { padding: 18px 20px; display: flex; flex-direction: column; gap: 10px; }
  .feat-main .feat-body { padding: 22px 24px 26px; }
  .feat-empty { border: 1px dashed var(--line-2); border-radius: 6px; padding: clamp(32px, 5vw, 52px); text-align: center; }
  .feat-empty .mono { display: block; }
  .feat-empty p { color: var(--ink-2); margin: 12px auto 0; max-width: 44ch; }
  .feat-empty a { border-bottom: 1px solid var(--accent-line); }

  .home-blog { padding-block: clamp(48px, 7vw, 80px) 0; }
  .post-list { border-top: 1px solid var(--line); }
  .post-row { display: grid; grid-template-columns: 120px 1fr auto; gap: 28px; align-items: baseline; padding: 22px 4px; border-bottom: 1px solid var(--line); transition: background 0.15s ease, padding-left 0.15s ease; }
  .post-row:hover { background: var(--paper-2); padding-left: 14px; }
  .post-row .pr-date { font-family: var(--mono); font-size: 12px; color: var(--ink-3); letter-spacing: 0.04em; }
  .post-row .pr-title { font-size: 20px; font-weight: 500; letter-spacing: -0.018em; }
  .post-row .pr-excerpt { color: var(--ink-2); font-size: 15px; margin-top: 5px; max-width: 62ch; }
  .post-row .pr-cat { justify-self: end; white-space: nowrap; }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; align-items: start; }
    .feat-grid { grid-template-columns: 1fr; }
    .post-row { grid-template-columns: 1fr; gap: 6px; }
    .post-row .pr-cat { justify-self: start; }
  }
</style>
