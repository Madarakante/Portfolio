---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Ngwashi Anthony" active="about">
  <main data-screen-label="About">
    <section class="wrap about-top">
      <div>
        <span class="kicker">About — still very much learning</span>
        <h1 class="h-xl">I'm learning to make<br />things move.</h1>
        <div class="about-bio">
          <p>I'm Anthony, a second-year <strong>mechatronics engineering student</strong>. I'm fascinated by the overlap of <strong>mechanism, circuit, and code</strong> — the place where a bit of Arduino, a couple of motors, and a 3D-printed bracket add up to something that actually does a job.</p>
          <p>I started with the classic blink-an-LED two years ago and haven't stopped since. These days I build small robots and gadgets in my spare time, break them, and write up what I learned — partly to remember it, partly because beginner-friendly explanations are weirdly hard to find.</p>
          <p>This site is my portfolio and my notebook. If you're learning too, I hope the build logs save you an afternoon or two.</p>
        </div>
      </div>
      <div class="portrait">
        <div class="frame"><span class="frame-corner tl"></span><span class="frame-corner tr"></span><span class="frame-corner bl"></span><span class="frame-corner br"></span><span class="frame-label">portrait — at my desk</span></div>
        <div class="pcap">Mostly built at the kitchen table</div>
      </div>
    </section>

    <section class="wrap section">
      <div class="sec-label">Capabilities</div>
      <div class="skills-grid">
        <div class="skill-col">
          <h3>Mechanical</h3>
          <ul>
            <li><span>3D CAD (Fusion)</span><span class="lvl">LEARNING</span></li>
            <li><span>3D printing</span><span class="lvl">COMFY</span></li>
            <li><span>Hand tools</span><span class="lvl">COMFY</span></li>
            <li><span>Laser-cut parts</span><span class="lvl">SOME</span></li>
            <li><span>Basic mechanisms</span><span class="lvl">LEARNING</span></li>
          </ul>
        </div>
        <div class="skill-col">
          <h3>Electronics</h3>
          <ul>
            <li><span>Breadboarding</span><span class="lvl">COMFY</span></li>
            <li><span>Soldering</span><span class="lvl">GETTING THERE</span></li>
            <li><span>Reading a multimeter</span><span class="lvl">COMFY</span></li>
            <li><span>KiCad / PCB design</span><span class="lvl">LEARNING</span></li>
            <li><span>Motors &amp; drivers</span><span class="lvl">SOME</span></li>
          </ul>
        </div>
        <div class="skill-col">
          <h3>Code</h3>
          <ul>
            <li><span>Arduino C/C++</span><span class="lvl">COMFY</span></li>
            <li><span>Python</span><span class="lvl">COURSEWORK</span></li>
            <li><span>Sensors &amp; I/O</span><span class="lvl">LEARNING</span></li>
            <li><span>Simple control loops</span><span class="lvl">LEARNING</span></li>
            <li><span>Git basics</span><span class="lvl">SOME</span></li>
          </ul>
        </div>
      </div>
    </section>

    <section class="wrap section">
      <div class="sec-label">Track</div>
      <div class="tl">
        <div class="tl-row"><span class="yr">2025 — NOW</span><div><div class="role">B.Eng Mechatronics — 2nd year</div><div class="org">Coursework in embedded systems, control, and electronics. Where most of these projects start.</div></div></div>
        <div class="tl-row"><span class="yr">2024</span><div><div class="role">Robotics society member</div><div class="org">Helping with the club's line-follower and sumo-bot builds — and learning to solder properly.</div></div></div>
        <div class="tl-row"><span class="yr">2023</span><div><div class="role">First Arduino starter kit</div><div class="org">Blinked an LED, then couldn't stop. The beginning of all of this.</div></div></div>
        <div class="tl-row"><span class="yr">GOAL</span><div><div class="role">Summer internship</div><div class="org">Looking for a first hands-on role in robotics, embedded, or hardware.</div></div></div>
      </div>
    </section>

    <section class="wrap section">
      <div class="sec-label">Contact</div>
      <div class="contact">
        <div class="c-left">
          <h2>Want to talk shop, or offer an internship?</h2>
          <p>I'm always happy to chat about a project, swap beginner tips, or hear about a summer role. My inbox is open.</p>
          <a class="btn" href="mailto:Contact@anthonycodes.tech" style="margin-top:24px;">Say hello <span class="arrow">→</span></a>
        </div>
        <div class="c-right">
          <a class="clink" href="mailto:Contact@anthonycodes.tech"><span class="cl-k">Email</span><span class="cl-v">Contact@anthonycodes.tech <span class="arrow accent">→</span></span></a>
          <a class="clink" href="mailto:antoniokante2.0@gmail.com"><span class="cl-k">Email (personal)</span><span class="cl-v">antoniokante2.0@gmail.com <span class="arrow accent">→</span></span></a>
          <a class="clink" href="https://github.com/Madarkante"><span class="cl-k">GitHub</span><span class="cl-v">@Madarkante <span class="arrow accent">→</span></span></a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about-top { padding-block: clamp(48px, 7vw, 84px) 0; display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(32px, 5vw, 64px); align-items: start; }
  .about-top h1 { margin-top: 16px; }
  .about-bio { margin-top: 26px; font-size: 18px; line-height: 1.7; color: var(--ink-2); }
  .about-bio p { margin-bottom: 1.15em; }
  .about-bio strong { color: var(--ink); font-weight: 600; }
  .portrait .frame { aspect-ratio: 4 / 5; }
  .portrait .pcap { font-family: var(--mono); font-size: 11px; letter-spacing: 0.04em; color: var(--ink-3); margin-top: 9px; }

  .section { padding-block: clamp(48px, 6vw, 72px) 0; }
  .sec-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 24px; display: flex; align-items: center; gap: 12px; }
  .sec-label::before { content: ""; width: 24px; height: 1px; background: var(--accent); }

  .skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--line); border-radius: 6px; overflow: hidden; }
  .skill-col { padding: 24px; border-right: 1px solid var(--line); }
  .skill-col:last-child { border-right: 0; }
  .skill-col h3 { font-family: var(--mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; font-weight: 600; }
  .skill-col ul { list-style: none; margin: 0; padding: 0; }
  .skill-col li { font-size: 15px; padding: 7px 0; border-bottom: 1px dashed var(--line-2); display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .skill-col li:last-child { border-bottom: 0; }
  .skill-col li .lvl { font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; color: var(--ink-3); }

  .tl { border-top: 1px solid var(--line); }
  .tl-row { display: grid; grid-template-columns: 130px 1fr; gap: 28px; padding: 22px 0; border-bottom: 1px solid var(--line); }
  .tl-row .yr { font-family: var(--mono); font-size: 13px; color: var(--ink-3); letter-spacing: 0.04em; }
  .tl-row .role { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; }
  .tl-row .org { color: var(--ink-2); font-size: 15px; margin-top: 3px; }

  .contact { border: 1px solid var(--line); border-radius: 6px; background: var(--paper); display: grid; grid-template-columns: 1.2fr 1fr; overflow: hidden; }
  .contact .c-left { padding: clamp(28px, 4vw, 44px); border-right: 1px solid var(--line); }
  .contact .c-left h2 { font-size: clamp(26px, 3vw, 36px); letter-spacing: -0.025em; font-weight: 500; }
  .contact .c-left p { color: var(--ink-2); margin-top: 14px; max-width: 34ch; }
  .contact .c-right { padding: clamp(24px, 3vw, 36px); display: flex; flex-direction: column; }
  .clink { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; border-bottom: 1px dashed var(--line-2); transition: padding-left .15s, color .15s; }
  .clink:last-child { border-bottom: 0; }
  .clink:hover { padding-left: 8px; }
  .clink .cl-k { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-3); }
  .clink .cl-v { font-size: 16px; font-weight: 500; display: flex; align-items: center; gap: 10px; }
  .clink:hover .cl-v { color: var(--accent); }

  @media (max-width: 860px) {
    .about-top { grid-template-columns: 1fr; }
    .portrait { max-width: 320px; }
    .skills-grid { grid-template-columns: 1fr; }
    .skill-col { border-right: 0; border-bottom: 1px solid var(--line); }
    .skill-col:last-child { border-bottom: 0; }
    .contact { grid-template-columns: 1fr; }
    .contact .c-left { border-right: 0; border-bottom: 1px solid var(--line); }
    .tl-row { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
